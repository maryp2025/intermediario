# Monolithic Dockerfile for HuggingFace Spaces / VPS (Multi-Arch)
# Includes FlareSolverr v3 (Python) and Byparr (Python Version)

FROM python:3.11-bookworm

# 1. Environment Settings
WORKDIR /app
ENV PYTHONUNBUFFERED=1
ENV FLARESOLVERR_URL=http://localhost:8191
ENV BYPARR_URL=http://localhost:8192
ENV BYPARR_PORT=8192
ENV PORT=7860

# 2. System Dependencies (Explicitly added Chromium for FlareSolverr)
RUN apt-get update && apt-get install -y \
    curl \
    git \
    ffmpeg \
    xvfb \
    chromium \
    libnss3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    libatspi2.0-0 \
    libxshmfence1 \
    libglu1-mesa \
    ca-certificates \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

# 3. FlareSolverr v3 Setup
RUN git clone https://github.com/FlareSolverr/FlareSolverr.git /app/flaresolverr \
    && cd /app/flaresolverr \
    && pip install --no-cache-dir -r requirements.txt

# 4. Byparr Setup (Cloned from source to support ARM/AMD)
RUN git clone https://github.com/ThePhaseless/Byparr.git /app/byparr_src \
    && cd /app/byparr_src \
    && pip install --no-cache-dir .

# 5. EasyProxy Setup
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
RUN python -m playwright install chromium

# Copy application files
COPY . .
RUN chmod +x entrypoint.sh

# 6. Execution
EXPOSE 7860
ENTRYPOINT ["/bin/bash", "/app/entrypoint.sh"]
